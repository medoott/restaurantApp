# Server Configuration
PORT=3000
NODE_ENV=dev
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# Database
DB_URL=mongodb://127.0.0.1:27017/restrunt
DB_POOL_SIZE=10
DB_SERVER_SELECTION_TIMEOUT_MS=10000
DB_SOCKET_TIMEOUT_MS=45000

# JWT Security
TOKEN_SECRET=your_super_secure_jwt_secret_use_at_least_32_chars
TOKEN_SECRET_ADMIN=another_super_secure_admin_secret_different_from_user
CRYPT_SECRET=your_aes_encryption_secret_use_at_least_32_chars_for_encryption
SALT=10
BCRYPT_ROUND=12

# Email & SMTP
EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_TOKEN_SECRET=your_email_token_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password

# JWT Email Confirmation
EMAIL_TOKEN_SECRET=your_email_token_secret_use_at_least_32_chars

# Frontend
FRONT_END_URL=https://your-frontend-domain.com
BACKEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
ORDER_RATE_LIMIT_WINDOW_MS=60000
ORDER_RATE_LIMIT_MAX_REQUESTS=5

# Timeout
REQUEST_TIMEOUT_MS=15000
SHUTDOWN_TIMEOUT_MS=30000
SOCKET_PING_INTERVAL_MS=25000
SOCKET_PING_TIMEOUT_MS=5000

# App Settings
APP_NAME="Brúne Coffee & Kitchen"
APP_DESCRIPTION="Premium coffee & kitchen experience"
APP_URL=https://coffee.com
SUPPORT_EMAIL=support@coffee.com
ADMIN_EMAIL=admin@coffee.com

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE_MB=10
LOG_MAX_FILES=7

# Security Headers
CUSTOM_NOCACHE_HEADERS=true
CUSTOM_CSP_ENABLED=true

# Input Validation
MAX_REQUEST_SIZE_MB=1
MAX_ARRAY_LENGTH=100
MAX_STRING_LENGTH=255

# Session
SESSION_TIMEOUT_MS=1800000
SESSION_CLEANUP_INTERVAL_MS=3600000
MAX_SESSIONS_PER_USER=5
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_PREVENT_REUSED=true
PASSWORD_REUSED_CHECK_COUNT=5

# Authentication
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME_MS=900000

# API Keys
API_KEY_REQUIRED=true
API_KEY_HEADER=X-API-Key
API_KEYS=dev_key_123,stage_key_456,prod_key_789

# Image Processing
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
IMAGE_QUALITY=85
THUMBNAIL_MAX_WIDTH=300
THUMBNAIL_MAX_HEIGHT=300

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Backups
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true
MAX_BACKUP_SIZE_MB=500

# WebSocket
WS_MAX_CONNECTIONS=1000
WS_HEARTBEAT_INTERVAL_MS=30000
WS_HEARTBEAT_TIMEOUT_MS=5000
WS_MESSAGE_SIZE_LIMIT_MB=10

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_CLEANUP_INTERVAL_MS=3600000

# Rate Limit for Analytics
ANALYTICS_RATE_LIMIT_WINDOW_MS=900000
ANALYTICS_RATE_LIMIT_MAX_REQUESTS=200

# CORS Allowed Origins
CORS_ALLOW_CREDENTIALS=true
CORS_EXPOSED_HEADERS=X-Total-Count,X-Page-Count

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_DB_TIMEOUT_MS=5000

# API Documentation
API_DOC_ENABLED=true
API_DOC_PATH=./docs/api.yaml

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs
SWAGGER_TITLE="Brúne Coffee & Kitchen API"
SWAGGER_DESCRIPTION="API for Brúne Coffee & Kitchen"
SWAGGER_VERSION=1.0.0

# MongoDB
MONGODB_REPLICA_SET=false
MONGODB_DIRECT_CONNECTION=false
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000

# Redis (if used)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_SECONDS=300

# External Services
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GOOGLE_MAPS_API_KEY=
STRIPE_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Notifications
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_EMAIL_FROM=noreply@coffee.com
NOTIFICATION_EMAIL_REPLY_TO=support@coffee.com
NOTIFICATION_PUSH_ENABLED=false
NOTIFICATION_SMS_ENABLED=false

# Queue
QUEUE_ENABLED=true
QUEUE_TYPE=bull
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_CONCURRENCY=5

# Retention
DATA_RETENTION_DAYS=365
LOG_RETENTION_DAYS=30
BACKUP_RETENTION_DAYS=30

# API Configuration
API_BASE_URL=http://localhost:3000
API_VERSION=1
API_PREFIX=/api
API_ENABLE_VERSIONING=true

# Feature Flags
NEW_FEATURE_ENABLED=false
MAINTENANCE_MODE=false
ENABLE_DEBUG_ROUTES=true

# Database
sSL_ENABLED=true
DB_HOST=localhost
DB_PORT=27017
DB_NAME=restrunt
DB_AUTH_SOURCE=admin
DB_SSL_CA=./db-ca.pem

# Email
smtp:
  host: smtp.gmail.com
  port: 587
  secure: true
  auth:
    user: your_email@gmail.com
    pass: your_email_app_password

# Task Queue
QUEUE_ENABLED=true
QUEUE_TYPE=redis
QUEUE_REDIS_URL=redis://localhost:6379
QUEUE_CONCURRENCY=10
QUEUE_RETRY_ATTEMPTS=3

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=300000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
ORDER_RATE_LIMIT_WINDOW_MS=60000
ORDER_RATE_LIMIT_MAX_REQUESTS=5

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf

# Security Headers
ENABLE_SECURITY_HEADERS=true
CONTENT_SECURITY_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';"

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=300000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE_MB=10
LOG_MAX_FILES=7

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090

# Session
SESSION_TIMEOUT_MS=1800000
SESSION_CLEANUP_INTERVAL_MS=3600000
SESSION_STORE_TYPE=memory
MAX_SESSIONS_PER_USER=5

# Database
DB_URL=mongodb://127.0.0.1:27017/restrunt

# Security
TOKEN_SIGNATURE=your_jwt_user_secret_here.use.at.least.32.chars.and.unique
TOKEN_SIGNATURE_ADMIN=your_jwt_admin_secret_here.use.at.least.32.chars.and.different
CRYPT_SIGNATURE=your_aes_encryption_secret_here.use.at.least.32.chars
SALT=8

# Email
EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password_here
EMAIL_TOKEN_SIGNATURE=your_email_token_secret.use.at.least.32.chars

# Frontend
FRONT_END_URL=http://localhost:5173